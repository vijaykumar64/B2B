# ─── Required ───────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<user>:<password>@cluster.mongodb.net/scaleup-bharat?retryWrites=true&w=majority"

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 characters each; use DIFFERENT values for access vs refresh
JWT_SECRET="replace-with-a-random-32+-char-string"
JWT_REFRESH_SECRET="replace-with-a-different-random-32+-char-string"

# Google Gemini API key (server-side only — never expose in frontend)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Optional with defaults ──────────────────────────────────────────────────

# Token expiry — access tokens are short-lived; refresh tokens are long-lived
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Allowed CORS origins (comma-separated for multiple)
# In production: set this to your exact frontend domain
CORS_ORIGIN="http://localhost:3001"

# Server port
PORT="3001"

# Logging level: error | warn | info | http | debug
LOG_LEVEL="info"

# Node environment
NODE_ENV="development"

# ─── Feature-specific ────────────────────────────────────────────────────────

# The URL where this app is hosted (used for OAuth callbacks, self-referential links)
APP_URL="http://localhost:3001"

# Google OAuth client ID (used by both frontend and backend for Google Sign-In)
VITE_GOOGLE_CLIENT_ID=""

# Admin email override — comma-separated list of emails that get admin role
# Example: "admin@yourcompany.com,support@yourcompany.com"
ADMIN_EMAILS=""
